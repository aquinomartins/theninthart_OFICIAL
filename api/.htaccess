Options -Indexes
RewriteEngine On

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set Cache-Control "no-store"
</IfModule>

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^v1(?:/(.*))?$ index.php?route=/v1/$1 [QSA,L]
RewriteRule ^(.*)$ index.php [QSA,L]
