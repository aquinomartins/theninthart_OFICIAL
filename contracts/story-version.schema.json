{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theninthart.example/contracts/story-version.schema.json",
  "title": "Versão narrativa",
  "description": "Família narrativa canônica.",
  "type": "object",
  "required": [
    "id",
    "versionNumber",
    "position",
    "title",
    "shortTitle",
    "description",
    "enabled",
    "temporalProfile",
    "worldProfile",
    "machineProfile",
    "kitchenProfile",
    "threatProfile",
    "emotionalProfile",
    "residueProfile",
    "titlePatterns",
    "abuelaLineThemes",
    "requiredTags",
    "preferredTags",
    "excludedTags",
    "defaultWidgetConfiguration",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^v0[1-7]$"
    },
    "versionNumber": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7
    },
    "position": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "shortTitle": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "temporalProfile": {
      "type": "object",
      "required": [
        "dominantEra",
        "past",
        "present",
        "future",
        "period"
      ],
      "properties": {
        "dominantEra": {
          "enum": [
            "past",
            "present",
            "future",
            "mixed"
          ]
        },
        "past": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "present": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "future": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "period": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "worldProfile": {
      "type": "object"
    },
    "machineProfile": {
      "type": "object"
    },
    "kitchenProfile": {
      "type": "object"
    },
    "threatProfile": {
      "type": "object"
    },
    "emotionalProfile": {
      "type": "object"
    },
    "residueProfile": {
      "type": "object"
    },
    "titlePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "abuelaLineThemes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "requiredTags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "preferredTags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "excludedTags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "defaultWidgetConfiguration": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
