{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dashboard-story-event.schema.json",
  "type": "object",
  "required": [
    "schemaVersion",
    "source",
    "timestamp"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "source": {
      "const": "dashboard"
    },
    "dashboardRevision": {
      "type": "integer",
      "minimum": 0
    },
    "featureId": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "widgetId": {
      "type": "string"
    },
    "parameterId": {
      "type": "string"
    },
    "value": {},
    "controls": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "widgets": {
      "type": "object"
    },
    "timestamp": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": true,
  "title": "Dashboard story event",
  "description": "Versioned Dashboard-to-Angular event payload."
}
