{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theninthart.example/contracts/story-widget.schema.json",
  "title": "Widget narrativo",
  "description": "Widget e parâmetros declarativos.",
  "type": "object",
  "required": [
    "id",
    "position",
    "title",
    "shortTitle",
    "description",
    "enabled",
    "activationButtonId",
    "panelId",
    "exclusivePanel",
    "parameters",
    "affectedQuadrants",
    "narrativeAxes",
    "futureCapabilities",
    "metadata"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "position": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "shortTitle": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "activationButtonId": {
      "type": "string",
      "minLength": 1
    },
    "panelId": {
      "type": "string",
      "minLength": 1
    },
    "exclusivePanel": {
      "type": "boolean"
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "description",
          "type",
          "defaultValue",
          "required",
          "enabled",
          "min",
          "max",
          "step",
          "unit",
          "options",
          "affectedAxes",
          "metadata"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "range",
              "number",
              "select",
              "boolean",
              "text"
            ]
          },
          "defaultValue": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "required": {
            "type": "boolean"
          },
          "enabled": {
            "type": "boolean"
          },
          "min": {
            "type": [
              "number",
              "null"
            ]
          },
          "max": {
            "type": [
              "number",
              "null"
            ]
          },
          "step": {
            "type": [
              "number",
              "null"
            ],
            "exclusiveMinimum": 0
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "options": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "affectedAxes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "metadata": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "affectedQuadrants": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 29
      },
      "uniqueItems": true
    },
    "narrativeAxes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "futureCapabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
